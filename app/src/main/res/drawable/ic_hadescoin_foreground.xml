        android:fillColor="#00000000"
        android:strokeWidth="3.5"
        android:pathData="M54,54m-33,0a33,33 0 1,0 66,0a33,33 0 1,0 -66,0">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="sweep"
                android:centerX="54"
                android:centerY="54">
                <item android:offset="0"   android:color="#FF6B00"/>
                <item android:offset="0.4" android:color="#FFAA00"/>
                <item android:offset="0.7" android:color="#FF8C00"/>
                <item android:offset="1"   android:color="#FF6B00"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ANILLO INTERIOR: fino morado (profundidad) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#7C3AED"
        android:strokeWidth="0.8"
        android:strokeAlpha="0.6"
        android:pathData="M54,54m-28,0a28,28 0 1,0 56,0a28,56 0 1,0 -56,0"/>

    <!-- LETRA H: glow halo morado -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#7C3AED"
        android:strokeWidth="3"
        android:strokeAlpha="0.35"
        android:pathData="M36,30 L36,78 L44,78 L44,57 L64,57 L64,78 L72,78 L72,30 L64,30 L64,51 L44,51 L44,30 Z"/>

    <!-- LETRA H: cuerpo con degradado vertical -->
    <path
        android:pathData="M36,30 L36,78 L44,78 L44,57 L64,57 L64,78 L72,78 L72,30 L64,30 L64,51 L44,51 L44,30 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="36"
                android:startY="30"
                android:endX="36"
                android:endY="78">
                <item android:offset="0"   android:color="#9F5FFF"/>
                <item android:offset="0.5" android:color="#7B2FE0"/>
                <item android:offset="1"   android:color="#3D0D99"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ESQUINAS BISELADAS de la H -->
    <path android:fillColor="#1A1A1A" android:pathData="M36,30 L42,30 L36,36 Z"/>
    <path android:fillColor="#1A1A1A" android:pathData="M72,30 L66,30 L72,36 Z"/>
    <path android:fillColor="#1A1A1A" android:pathData="M36,78 L42,78 L36,72 Z"/>
    <path android:fillColor="#1A1A1A" android:pathData="M72,78 L66,78 L72,72 Z"/>

    <!-- REFLEJO METÁLICO -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1"
        android:strokeAlpha="0.2"
        android:pathData="M37,31 L37,77 M45,52 L63,52 M65,31 L65,50"/>

